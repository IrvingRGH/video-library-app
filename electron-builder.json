{
    "appId": "com.vforsis.videolibrary",
    "productName": "Video Library",
    "directories": {
        "output": "release",
        "buildResources": "build"
    },
    "files": [
        "dist/**/*",
        "electron/**/*",
        "package.json"
    ],
    "win": {
        "target": [
            {
                "target": "nsis",
                "arch": [
                    "x64"
                ]
            }
        ],
        "icon": "public/icon.png"
    },
    "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true
    }
}